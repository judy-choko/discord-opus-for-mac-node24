{
	"name": "@judy-choko/discord-opus-for-mac-node24",
	"version": "0.10.0",
	"description": "Opus bindings for Node.js on macOS, built locally for Node 24 without remote prebuilt downloads",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/judy-choko/discord-opus-for-mac-node24.git"
	},
	"homepage": "https://github.com/judy-choko/discord-opus-for-mac-node24#readme",
	"bugs": {
		"url": "https://github.com/judy-choko/discord-opus-for-mac-node24/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"main": "lib/index.js",
	"types": "typings/index.d.ts",
	"author": "iCrawl <icrawltogo@gmail.com>",
	"license": "MIT",
	"scripts": {
		"install": "node-gyp rebuild",
		"build": "node-gyp rebuild",
		"lint": "prettier --check . && eslint lib --format=pretty",
		"lint:fix": "prettier --write . && eslint lib --fix --format=pretty",
		"test": "node tests/test.js"
	},
	"keywords": [
		"native",
		"opus",
		"module",
		"c",
		"c++",
		"bindings"
	],
	"os": [
		"darwin"
	],
	"cpu": [
		"x64",
		"arm64"
	],
	"files": [
		"lib",
		"src",
		"deps",
		"typings",
		"binding.gyp",
		"LICENSE",
		"README.md"
	],
	"dependencies": {
		"node-addon-api": "^8.5.0"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.1",
		"@types/node": "^25.0.0",
		"eslint": "^9.39.1",
		"node-gyp": "^12.1.0",
		"prettier": "^3.8.2",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.58.1"
	},
	"overrides": {
		"eslint-plugin-rxjs": "npm:@favware/skip-dependency@latest",
		"eslint-plugin-rxjs-angular": "npm:@favware/skip-dependency@latest",
		"eslint-plugin-typescript-sort-keys": "npm:@favware/skip-dependency@latest",
		"eslint-plugin-sonarjs": "npm:@favware/skip-dependency@latest",
		"eslint-plugin-vue": "npm:@favware/skip-dependency@latest"
	},
	"engines": {
		"node": ">=24 <25"
	}
}